ENVIRONMENT=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://ku_helper:ku_helper_dev@localhost:5432/ku_helper

# 비워두면 Redis 클라이언트 셋업을 skip한다 (§0 부트스트랩 한정).
REDIS_URL=

DISCORD_BOT_TOKEN=

# 콤마 구분 Discord ID 화이트리스트. F-22 관리자 알림 대상.
ADMIN_DISCORD_IDS=

# F-07 교통 알림에 필수. 서울 열린데이터광장(data.seoul.go.kr)에서 `realtimeStationArrival`
# 서비스로 인증키를 발급받아 넣는다. SecretStr 로 격리되어 로그에 출력되지 않는다.
SUBWAY_API_KEY=

# §C 즉시 발송 lunch DM 의 맛집 추천에 필수. 네이버 개발자센터(developers.naver.com)
# 에서 "검색" API 사용 설정 후 클라이언트 ID/Secret 발급. 둘 중 하나라도 비면 lifespan
# 에서 RestaurantsClient 가 None 으로 떨어져 run_immediate_send_lunch_job 이 skip 된다.
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=

# 건국대 학식 페이지 URL. 기본값(보드 URL)으로 충분하며, 페이지 구조가 바뀌면 갱신.
# CAFETERIA_URL=https://www.konkuk.ac.kr/general/18211/subview.do
