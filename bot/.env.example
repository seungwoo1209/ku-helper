ENVIRONMENT=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://ku_helper:ku_helper_dev@localhost:5432/ku_helper

# 비워두면 Redis 클라이언트 셋업을 skip한다 (§0 부트스트랩 한정).
REDIS_URL=

DISCORD_BOT_TOKEN=

# 콤마 구분 Discord ID 화이트리스트. F-22 관리자 알림 대상.
ADMIN_DISCORD_IDS=

# F-07 교통 알림에 필수. 서울 열린데이터광장(data.seoul.go.kr)에서 `realtimeStationArrival`
# 서비스로 인증키를 발급받아 넣는다. SecretStr 로 격리되어 로그에 출력되지 않는다.
SUBWAY_API_KEY=
