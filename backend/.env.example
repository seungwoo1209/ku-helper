# 환경
ENVIRONMENT=development
LOG_LEVEL=INFO

# 데이터베이스 (asyncpg)
DATABASE_URL=postgresql+asyncpg://ku_helper:ku_helper_dev@localhost:5432/ku_helper

# Redis (refresh token whitelist, 향후 캐시·쿨다운 키 공용)
REDIS_URL=redis://localhost:6379/0

# CORS (JSON 배열)
CORS_ORIGINS=["http://localhost:3000"]

# JWT
JWT_SECRET=change-me-please
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRY_MINUTES=30
JWT_REFRESH_EXPIRY_DAYS=30
JWT_STATE_EXPIRY_MINUTES=5

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_REDIRECT_URI=http://localhost:8000/api/v1/auth/discord/callback
DISCORD_OAUTH_SCOPES=["identify","applications.commands"]
# 1 = user-install, 0 = guild-install
DISCORD_INTEGRATION_TYPE=1
