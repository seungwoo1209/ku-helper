{
  "openapi": "3.1.0",
  "info": {
    "title": "ku-helper backend",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/auth/discord/login": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Login",
        "description": "Discord 인가 페이지로 사용자를 리다이렉트한다.",
        "operationId": "login_api_v1_auth_discord_login_get",
        "responses": {
          "307": {
            "description": "Successful Response"
          }
        }
      }
    },
    "/api/v1/auth/discord/callback": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Callback",
        "description": "Discord OAuth 콜백을 처리하고 자체 JWT를 발급한다.",
        "operationId": "callback_api_v1_auth_discord_callback_get",
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Code"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "State"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenRead"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/me": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "Get Me",
        "description": "현재 로그인한 사용자 정보를 반환한다.",
        "operationId": "get_me_api_v1_users_me_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserRead"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      },
      "delete": {
        "tags": [
          "users"
        ],
        "summary": "Delete Me",
        "description": "현재 사용자 계정을 삭제(소프트 삭제)한다.",
        "operationId": "delete_me_api_v1_users_me_delete",
        "responses": {
          "204": {
            "description": "Successful Response"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      },
      "patch": {
        "tags": [
          "users"
        ],
        "summary": "Update Me",
        "description": "현재 사용자 정보를 수정한다. (미구현)",
        "operationId": "update_me_api_v1_users_me_patch",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserUpdate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserRead"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/api/v1/me/notifications": {
      "get": {
        "tags": [
          "notifications"
        ],
        "summary": "List Notifications",
        "description": "현재 사용자의 모든 알림 설정을 반환한다.",
        "operationId": "list_notifications_api_v1_me_notifications_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/NotificationRead"
                  },
                  "type": "array",
                  "title": "Response List Notifications Api V1 Me Notifications Get"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      },
      "post": {
        "tags": [
          "notifications"
        ],
        "summary": "Create Notification",
        "description": "새 알림 설정을 생성한다.",
        "operationId": "create_notification_api_v1_me_notifications_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "anyOf": [
                  {
                    "$ref": "#/components/schemas/_TransitCreate"
                  },
                  {
                    "$ref": "#/components/schemas/_LunchCreate"
                  },
                  {
                    "$ref": "#/components/schemas/_LibraryCreate"
                  }
                ],
                "title": "Body"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationRead"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/api/v1/me/notifications/{notification_id}": {
      "get": {
        "tags": [
          "notifications"
        ],
        "summary": "Get Notification",
        "description": "단일 알림 설정을 반환한다.",
        "operationId": "get_notification_api_v1_me_notifications__notification_id__get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "notification_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "title": "Notification Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationRead"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "notifications"
        ],
        "summary": "Update Notification",
        "description": "알림 설정을 부분 수정한다. config는 전체 교체.",
        "operationId": "update_notification_api_v1_me_notifications__notification_id__patch",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "notification_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "title": "Notification Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NotificationUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationRead"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "notifications"
        ],
        "summary": "Delete Notification",
        "description": "알림 설정을 삭제한다.",
        "operationId": "delete_notification_api_v1_me_notifications__notification_id__delete",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "notification_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "title": "Notification Id"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Health Get"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LibraryConfig": {
        "properties": {
          "reading_room_id": {
            "type": "string",
            "maxLength": 50,
            "minLength": 1,
            "title": "Reading Room Id"
          },
          "threshold": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Threshold"
          },
          "urgent_threshold": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Urgent Threshold"
          }
        },
        "type": "object",
        "required": [
          "reading_room_id",
          "threshold"
        ],
        "title": "LibraryConfig"
      },
      "LunchConfig": {
        "properties": {
          "notify_at": {
            "type": "string",
            "format": "time",
            "title": "Notify At"
          },
          "max_price": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Price"
          },
          "recommend_count": {
            "type": "integer",
            "maximum": 10.0,
            "minimum": 1.0,
            "title": "Recommend Count",
            "default": 3
          }
        },
        "type": "object",
        "required": [
          "notify_at"
        ],
        "title": "LunchConfig"
      },
      "NotificationRead": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "user_id": {
            "type": "integer",
            "title": "User Id"
          },
          "type": {
            "$ref": "#/components/schemas/NotificationType"
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled"
          },
          "config": {
            "additionalProperties": true,
            "type": "object",
            "title": "Config"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "user_id",
          "type",
          "enabled",
          "config",
          "created_at",
          "updated_at"
        ],
        "title": "NotificationRead"
      },
      "NotificationType": {
        "type": "string",
        "enum": [
          "TRANSIT",
          "LUNCH",
          "LIBRARY"
        ],
        "title": "NotificationType"
      },
      "NotificationUpdate": {
        "properties": {
          "enabled": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Enabled"
          },
          "config": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Config"
          }
        },
        "type": "object",
        "title": "NotificationUpdate"
      },
      "TokenRead": {
        "properties": {
          "access_token": {
            "type": "string",
            "title": "Access Token"
          },
          "refresh_token": {
            "type": "string",
            "title": "Refresh Token"
          },
          "token_type": {
            "type": "string",
            "title": "Token Type",
            "default": "bearer"
          }
        },
        "type": "object",
        "required": [
          "access_token",
          "refresh_token"
        ],
        "title": "TokenRead"
      },
      "TransitConfig": {
        "properties": {
          "station_name": {
            "type": "string",
            "maxLength": 50,
            "minLength": 1,
            "title": "Station Name"
          },
          "line": {
            "type": "string",
            "maxLength": 20,
            "minLength": 1,
            "title": "Line"
          },
          "minutes_before": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 120.0,
                "minimum": 1.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Minutes Before"
          },
          "repeat_interval_minutes": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 180.0,
                "minimum": 1.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Repeat Interval Minutes"
          },
          "include_congestion": {
            "type": "boolean",
            "title": "Include Congestion",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "station_name",
          "line"
        ],
        "title": "TransitConfig"
      },
      "UserRead": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "discord_id": {
            "type": "integer",
            "title": "Discord Id"
          },
          "discord_username": {
            "type": "string",
            "title": "Discord Username"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "discord_id",
          "discord_username",
          "created_at",
          "updated_at"
        ],
        "title": "UserRead"
      },
      "UserUpdate": {
        "properties": {},
        "type": "object",
        "title": "UserUpdate"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "_LibraryCreate": {
        "properties": {
          "type": {
            "type": "string",
            "const": "LIBRARY",
            "title": "Type"
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled",
            "default": true
          },
          "config": {
            "$ref": "#/components/schemas/LibraryConfig"
          }
        },
        "type": "object",
        "required": [
          "type",
          "config"
        ],
        "title": "_LibraryCreate"
      },
      "_LunchCreate": {
        "properties": {
          "type": {
            "type": "string",
            "const": "LUNCH",
            "title": "Type"
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled",
            "default": true
          },
          "config": {
            "$ref": "#/components/schemas/LunchConfig"
          }
        },
        "type": "object",
        "required": [
          "type",
          "config"
        ],
        "title": "_LunchCreate"
      },
      "_TransitCreate": {
        "properties": {
          "type": {
            "type": "string",
            "const": "TRANSIT",
            "title": "Type"
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled",
            "default": true
          },
          "config": {
            "$ref": "#/components/schemas/TransitConfig"
          }
        },
        "type": "object",
        "required": [
          "type",
          "config"
        ],
        "title": "_TransitCreate"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}