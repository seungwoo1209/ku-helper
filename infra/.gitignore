# Terraform state
*.tfstate
*.tfstate.*
*.tfstate.backup
crash.log
crash.*.log

# Terraform working directory & lock
.terraform/
.terraform.lock.hcl

# Variable files that may contain secrets
*.tfvars
*.tfvars.json
!example.tfvars

# Plan output
*.tfplan

# Generated private keys / certificates
*.pem
*.key

# AWS credentials (should never be committed)
.aws/
aws-credentials*
credentials
.env
.env.*

